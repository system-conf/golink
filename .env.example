# Turso (libSQL) — turso db create systemconf-go
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Upstash Redis (rate limit) — bırakırsan rate limit devre dışı kalır
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# IP hashing — rastgele 32 byte hex string üret (openssl rand -hex 32)
IP_HASH_SALT=

# Public origin (kart ekranında oluşturulan tam URL için)
NEXT_PUBLIC_BASE_URL=https://go.systemconf.online

# Vercel Cron auth — bırakırsan endpoint açık olur (Vercel Cron header eklemez)
CRON_SECRET=
